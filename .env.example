# ── Supabase PostgreSQL（Prisma）────────────────────────────────────────
# Transaction pooler（应用运行时推荐，端口 6543）
# Prisma 需要 pgbouncer=true；本仓库 resolveDatabaseUrl 会自动补全
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# 直连（migrate / pooler 不可用时 fallback，端口 5432）
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# pooler 连不上时，在 .env.local 临时改为直连：
# PRISMA_USE_DIRECT_URL=1

# dev：DB 不可用时 /api/entitlements 降级档位（free | pro | enterprise）
# DEV_ENTITLEMENT_FALLBACK_LEVEL=enterprise

# 关闭 dev 权益降级（连不上 DB 则 503）
# ENTITLEMENT_DB_FALLBACK=0
