###############################################################################
# Core policy
###############################################################################

# Default: use LF in repository
* text=auto eol=lf

###############################################################################
# Lockfiles (must be stable across platforms)
###############################################################################

package-lock.json text eol=lf
pnpm-lock.yaml text eol=lf
yarn.lock text eol=lf

###############################################################################
# JSON / TS / JS (cross-platform safe)
###############################################################################

*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf

###############################################################################
# PowerShell scripts (Windows-friendly)
###############################################################################

*.ps1 text eol=crlf

###############################################################################
# Markdown
###############################################################################

*.md text eol=lf

###############################################################################
# Binary files (never modify line endings)
###############################################################################

*.pdf binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
