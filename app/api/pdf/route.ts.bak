// app/api/pdf/route.ts
import { NextRequest } from "next/server";
import crypto from "crypto";
import { prisma } from "@/lib/prisma";
import {
  getClientIp,
  verifyAndConsumePdfToken,
  logPdfDownload,
} from "@/lib/pdfDownloadToken";

// ✅ 你已有的 PDF 渲染函数：按你项目实际路径接回
// import { renderPdfBuffer } from "@/lib/pdf/render";
// import { renderPreviewPdfBuffer } from "@/lib/pdf/renderPreview";

// 与 lib/session.ts 保持一致：优先使用 SESSION_SECRET，然后是 SESSION_TOKEN_SECRET
const SESSION_SECRET = process.env.SESSION_SECRET || process.env.SESSION_TOKEN_SECRET || "";

function hashSessionToken(rawToken: string) {
  // 与 lib/session.ts 保持一致的哈希算法：
  // lib/session.ts 使用 sha256(`${token}:${process.env.SESSION_SECRET ?? "sess"}`)
  const secret = SESSION_SECRET || "sess"; // 与 lib/session.ts 的默认值保持一致
  return crypto.createHash("sha256").update(`${rawToken}:${secret}`).digest("hex");
}

function shouldBypassPaywall() {
  // 生产环境永远不绕过
  if (process.env.NODE_ENV === "production") return false;
  // 开发环境：必须显式设置为 1 才绕过
  return process.env.PDF_PAYWALL_BYPASS === "1";
}

async function requireLogin(req: NextRequest) {
  const cookie = req.headers.get("cookie") || "";

  // 只匹配你实际用到的 cookie 名
  const candidates = ["session", "sessionToken", "auth_token", "next-auth.session-token"];

  let rawToken: string | null = null;
  for (const name of candidates) {
    const m = cookie.match(new RegExp(`${name}=([^;]+)`));
    if (m?.[1]) {
      rawToken = decodeURIComponent(m[1]);
      break;
    }
  }

  if (!rawToken) return { ok: false as const };

  const secret = SESSION_SECRET || "sess"; // 与 lib/session.ts 的默认值保持一致
  if (!SESSION_SECRET) {
    // 在本地可以短路，但生产必须提供 SESSION_SECRET 或 SESSION_TOKEN_SECRET
    console.warn("SESSION_SECRET/SESSION_TOKEN_SECRET not set; using default 'sess'");
  }

  // 计算与 DB 一致的 hash
  const tokenHash = hashSessionToken(rawToken);
  
  // 调试日志（仅开发环境）
  if (process.env.NODE_ENV !== "production") {
    console.log(`[requireLogin] rawToken: ${rawToken.substring(0, 20)}..., secret: ${secret}, tokenHash: ${tokenHash.substring(0, 20)}...`);
  }

  const row = await prisma.session.findUnique({
    where: { tokenHash },
    select: { email: true, expiresAt: true },
  });

  if (!row) {
    if (process.env.NODE_ENV !== "production") {
      console.log(`[requireLogin] 数据库中未找到匹配的 tokenHash`);
    }
    return { ok: false as const };
  }
  if (row.expiresAt.getTime() <= Date.now()) return { ok: false as const };

  return { ok: true as const, email: row.email };
}

function pdfResponse(buf: Buffer | Uint8Array, filename: string) {
  return new Response(buf as BodyInit, {
    headers: {
      "Content-Type": "application/pdf",
      "Content-Disposition": `attachment; filename="${filename}"`,
      "Cache-Control": "no-store",
    },
  });
}

export async function GET(req: NextRequest) {
  const url = new URL(req.url);
  const planId = String(url.searchParams.get("planId") || "").trim();
  const mode = String(url.searchParams.get("mode") || "full").trim(); // preview | full
  const downloadToken = url.searchParams.get("downloadToken");

  if (!planId) {
    return Response.json({ ok: false, code: "MISSING_PLAN_ID" }, { status: 400 });
  }

  const ip = getClientIp(req.headers);
  const userAgent = req.headers.get("user-agent") || undefined;

  // -------------------------
  // A) Preview：必须登录
  // -------------------------
  if (mode === "preview") {
    const s = await requireLogin(req);
    if (!s.ok) {
      await logPdfDownload({
        planId,
        ok: false,
        reason: "LOGIN_REQUIRED",
        ip,
        userAgent,
      });
      return Response.json({ ok: false, code: "LOGIN_REQUIRED" }, { status: 401 });
    }

    // ✅ 这里接你的 preview 渲染（建议：仅前两页/水印）
    // const pdf = await renderPreviewPdfBuffer(planId, { email: s.email });
    // return pdfResponse(pdf, `${planId}-preview.pdf`);

    // 临时返回（你接好渲染后删掉）
    await logPdfDownload({ planId, ok: true, reason: "PREVIEW_OK", ip, userAgent });
    return Response.json({ ok: true, code: "PREVIEW_OK" }, { status: 200 });
  }

  // -------------------------
  // B) Full：生产不绕过；开发可绕过但必须显式开关
  // -------------------------
  if (!shouldBypassPaywall()) {
    const gate = await verifyAndConsumePdfToken({
      planId,
      rawToken: downloadToken,
      ip,
      userAgent,
    });

    if (!gate.ok) {
      const status =
        gate.code === "TOKEN_EXHAUSTED" ? 429 :
        gate.code === "MISSING_TOKEN" ? 403 :
        403;

      // verifyAndConsumePdfToken 已写日志，这里无需重复
      return Response.json({ ok: false, code: gate.code }, { status });
    }

    // ✅ 通过门禁后再渲染 full PDF
    // const pdf = await renderPdfBuffer(planId, { mode: gate.mode ?? "full" });
    // return pdfResponse(pdf, `${planId}.pdf`);

    await logPdfDownload({ planId, ok: true, reason: "FULL_OK", ip, userAgent });
    return Response.json({ ok: true, code: "FULL_OK", mode: gate.mode ?? null }, { status: 200 });
  }

  // 开发绕过（仅开发）
  await logPdfDownload({ planId, ok: true, reason: "DEV_BYPASS", ip, userAgent });

  // const pdf = await renderPdfBuffer(planId, { mode: "full" });
  // return pdfResponse(pdf, `${planId}.pdf`);

  return Response.json({ ok: true, code: "DEV_BYPASS" }, { status: 200 });
}

