// app/api/pdf/route.ts
import { NextRequest, NextResponse } from "next/server";

export const runtime = "nodejs";
export const dynamic = "force-dynamic";

function json(status: number, code: string, message: string, extra?: any) {
  return NextResponse.json(
    { ok: false, code, message, ...(extra ? { extra } : {}) },
    { status }
  );
}

function pick<T extends string>(v: string | null, allowed: readonly T[], fallback: T): T {
  if (!v) return fallback;
  const s = String(v).trim() as T;
  return (allowed as readonly string[]).includes(s) ? s : fallback;
}

function toInt(v: string | null, fallback: number) {
  const n = Number.parseInt(String(v ?? "").trim(), 10);
  return Number.isFinite(n) ? n : fallback;
}

export async function GET(req: NextRequest) {
  console.log(">>> ENTER /api/pdf");
  try {
    const { searchParams } = new URL(req.url);

    const planId = (searchParams.get("planId") || "").trim();
    if (!planId) return json(400, "MISSING_PLAN_ID", "Missing planId");

    const mode = pick(searchParams.get("mode"), ["preview", "full", "budget"] as const, "full");

    // ✅ 预算：动态 import + 兼容 default/named
    if (mode === "budget") {
      const companyName = (searchParams.get("companyName") || "某某集团").trim();

      const companySizeRaw = toInt(searchParams.get("companySize"), 100);
      const companySize =
        companySizeRaw === 50 || companySizeRaw === 100 || companySizeRaw === 200
          ? (companySizeRaw as 50 | 100 | 200)
          : (100 as 50 | 100 | 200);

      const budgetTier = pick(searchParams.get("budgetTier"), ["low", "mid", "high"] as const, "mid");

      const pdfVersion = (searchParams.get("pdfVersion") || "BUDGET_PDF_TENDER").trim();
      const bidderName = (searchParams.get("bidderName") || "").trim();

      // 1) 先尝试 lib/pdf/budget 的 named export
      const budgetMod = await import("@/lib/pdf/budget").catch(() => null);
      const named = budgetMod && (budgetMod as any).renderBudgetPdfBuffer;

      // 2) 再尝试 lib/pdf/renderBudget 的 default export（你现在就是这里炸）
      const rbMod = await import("@/lib/pdf/renderBudget").catch(() => null);
      const def = rbMod && (rbMod as any).default;

      const fn =
        typeof named === "function"
          ? named
          : typeof def === "function"
            ? def
            : null;

      if (!fn) {
        return json(500, "BUDGET_RENDER_NOT_FOUND", "No budget render function found", {
          budgetExports: budgetMod ? Object.keys(budgetMod as any) : null,
          renderBudgetExports: rbMod ? Object.keys(rbMod as any) : null,
        });
      }

      const bytes: Uint8Array = await fn(
        {
          planId,
          companyName,
          companySize,
          budgetTier,
        },
        {
          pdfVersion,
          bidderName,
          tenderPreset: "new_build",
        }
      );

      const buf = Buffer.from(bytes);
      return new NextResponse(buf, {
        status: 200,
        headers: {
          "Content-Type": "application/pdf",
          "Content-Disposition": `inline; filename="${encodeURIComponent(`${pdfVersion}-${planId}.pdf`)}"`,
          "Cache-Control": "no-store, must-revalidate",
        },
      });
    }

    // 其他模式照旧
    const { renderPdf } = await import("@/lib/pdf/render");
    const bytes = await renderPdf(planId, { mode });
    return new NextResponse(Buffer.from(bytes), {
      status: 200,
      headers: {
        "Content-Type": "application/pdf",
        "Content-Disposition": `inline; filename="${encodeURIComponent(`${mode}-${planId}.pdf`)}"`,
        "Cache-Control": "no-store, must-revalidate",
      },
    });
  } catch (e: any) {
    return json(500, "PDF_INTERNAL_ERROR", e?.message || "Unknown error", {
      name: e?.name,
      stack: e?.stack,
    });
  }
}