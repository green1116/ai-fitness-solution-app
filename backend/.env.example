# ===== 基础配置 =====
PORT=3000
BASE_URL=http://localhost:3000
ADMIN_TOKEN=change_me_please_use_strong_password

# ===== OpenAI 配置 =====
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_TOKENS=1400
OPENAI_TEMPERATURE=0.2
OPENAI_RETRIES=2

# ===== PDF 配置 =====
PDF_FORMAT=A4

# ===== Stripe 支付（可选）=====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== SMTP 邮件配置 =====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
MAIL_FROM="AI Judgment <your_email@example.com>"
MAIL_TO_OPS=ops@example.com

# ===== 企业微信 Webhook（可选）=====
# 获取方式：进入群聊 → 右上角 → 群机器人 → 添加机器人 → 复制 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxx

# ===== 飞书 Webhook（可选）=====
# 获取方式：群聊 → 添加机器人（自定义机器人）→ 复制 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# ===== 数据库配置（可选）=====
# 如果以后接订单校验，配置数据库/服务
# DB_URL=postgresql://user:password@localhost:5432/dbname
# 或
# DB_URL=mysql://user:password@localhost:3306/dbname

